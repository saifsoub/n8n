# Server runtime
PORT=5678
NODE_ENV=production

# Database (PostgreSQL)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=your-db-host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=your-db-name
DB_POSTGRESDB_USERNAME=your-db-username
DB_POSTGRESDB_PASSWORD=your-db-password
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# Optional database schema
DB_POSTGRESDB_SCHEMA=public

# Authentication & Security
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin-password
ENCRYPTION_KEY=your-encryption-key

# Webhook URL (publicly accessible to your instance)
WEBHOOK_URL=https://your-n8n-instance.com/

# External services (replace placeholders with real keys)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BLUECONIC_API_KEY=your-blueconic-api-key
FIGMA_API_TOKEN=your-figma-api-token
STRIPE_SECRET_KEY=your-stripe-secret-key
MAILGUN_API_KEY=your-mailgun-api-key

# Application info
APP_NAME=n8n-app
APP_URL=https://your-n8n-instance.com

# Copy this file to .env and replace placeholders with real values
