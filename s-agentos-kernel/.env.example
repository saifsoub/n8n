# ============================================================================
# S/ AgentOS Kernel v0.1 — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT SECURITY WARNINGS:
#   - NEVER commit .env to version control.
#   - NEVER expose S_AGENTOS_OPERATOR_KEY in logs, URLs, or client-side code.
#   - NEVER expose SUPABASE_SERVICE_ROLE_KEY to the browser or client apps.
#   - Use strong, randomly generated keys (use: openssl rand -base64 32).
# ============================================================================

# ============================================================================
# n8n Configuration
# ============================================================================
N8N_HOST=your-domain.com
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change-me-to-a-random-string-min-16-chars
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
N8N_WEBHOOK_URL=https://your-domain.com/

# ============================================================================
# PostgreSQL (n8n Internal Database)
# ============================================================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=change-me-postgres-password
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=change-me-postgres-password

# ============================================================================
# Supabase (AgentOS Operating Memory)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ============================================================================
# AgentOS Kernel Settings
# ============================================================================
S_AGENTOS_KERNEL_VERSION=0.2.0
S_AGENTOS_OPERATOR_KEY=change-me-operator-key-for-webhook-auth
S_AGENTOS_API_TOKEN=change-me-operator-key-for-webhook-auth

# ============================================================================
# LLM Providers (Optional)
# ============================================================================
OPENAI_API_KEY=sk-...optional
ANTHROPIC_API_KEY=sk-ant-...optional
GROQ_API_KEY=gsk_...optional
