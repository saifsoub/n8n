# ============================================================================
# S/ AgentOS Kernel v0.1 — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT SECURITY WARNINGS:
#   - NEVER commit .env to version control. Add it to .gitignore.
#   - NEVER expose S_AGENTOS_OPERATOR_KEY in logs, URLs, or client-side code.
#   - NEVER expose SUPABASE_SERVICE_ROLE_KEY to the browser or client apps.
#     Use the anon/public key for client-side operations.
#   - Use strong, randomly generated keys (use: openssl rand -base64 32).
#   - Rotate keys immediately if they are exposed or compromised.
#   - n8n Basic Auth should ALWAYS be enabled in production.
#   - HTTPS is required for webhook endpoints receiving external data.
# ============================================================================

# ============================================================================
# n8n Configuration
# ============================================================================
# The public domain or IP address where n8n is accessible.
# Examples: n8n.yourdomain.com, your-vps-ip
N8N_HOST=your-domain.com

# Protocol for n8n URLs. Use "https" in production (required for webhooks).
N8N_PROTOCOL=https

# Port n8n listens on inside the container. Default is 5678.
N8N_PORT=5678

# Encryption key for n8n credentials. Must be at least 16 characters.
# Generate with: openssl rand -base64 24
# Losing this key means losing access to all stored credentials.
N8N_ENCRYPTION_KEY=change-me-to-a-random-string-min-16-chars

# Enable Basic Auth for the n8n web UI. HIGHLY recommended for production.
N8N_BASIC_AUTH_ACTIVE=true

# Username for n8n Basic Auth login.
N8N_BASIC_AUTH_USER=admin

# Password for n8n Basic Auth login. Use a strong, unique password.
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password

# Public webhook URL (must match your reverse proxy / public domain).
# This is the base URL used in webhook triggers and OAuth callbacks.
# Must use HTTPS in production.
N8N_WEBHOOK_URL=https://your-domain.com/

# ============================================================================
# PostgreSQL (n8n Internal Database)
# ============================================================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=change-me-postgres-password
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=change-me-postgres-password

# ============================================================================
# Supabase (AgentOS Operating Memory)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ============================================================================
# AgentOS Kernel Settings
# ============================================================================
S_AGENTOS_KERNEL_VERSION=0.1.3
S_AGENTOS_OPERATOR_KEY=change-me-operator-key-for-webhook-auth
S_AGENTOS_API_TOKEN=change-me-operator-key-for-webhook-auth

# ============================================================================
# LLM Providers (Optional for v0.1)
# ============================================================================
OPENAI_API_KEY=sk-...optional
ANTHROPIC_API_KEY=sk-ant-...optional
GROQ_API_KEY=gsk_...optional
