    {"id":"df89bcbc-f8a0-47e1-84e1-0b1ba0467ec4","name":"Code — Normalize Command","type":"n8n-nodes-base.code","typeVersion":2,"position":[250,1200],"parameters":{"mode":"runOnceForAllItems","jsCode":"const body = $input.first().json.body || {};\nconst ts = Date.now();\nconst rand = () => Math.random().toString(36).substring(2, 8);\nconst command_id = body.command_id || ('cmd_' + ts + '_' + rand());\nconst trace_id = body.trace_id || ('trace_' + ts + '_' + rand());\nconst idempotency_key = body.idempotency_key || null;\nconst normalized = {\n  command_id,\n  trace_id,\n  idempotency_key,\n  action: body.action || 'unknown',\n  objective: body.objective || '',\n  requested_by: body.requested_by || 'operator',\n  priority: body.priority || 'normal',\n  agent_id: body.agent_id || null,\n  run_mode: body.run_mode || 'draft',\n  approval_status: body.approval_status || 'not_required',\n  context: body.context || {},\n  metadata: body.metadata || {},\n  status: 'received',\n  response: null,\n  received_at: new Date().toISOString(),\n  kernel_version: '0.2.0'\n};\nreturn [{ json: normalized }];"}},
