  "nodes": [
    {"id":"41922a57-72e3-49e0-bddc-bfe087337022","name":"Webhook — Command Entry","type":"n8n-nodes-base.webhook","typeVersion":2,"position":[250,200],"webhookId":"s-agentos-command","parameters":{"httpMethod":"POST","path":"s-agentos-command","responseMode":"responseNode","options":{}},"credentials":{"httpBasicAuth":{"name":"Command Gateway Auth"}}},
    {"id":"ebd94add-a998-4e1f-80f2-6275cc451da2","name":"Code — Extract & Validate Auth","type":"n8n-nodes-base.code","typeVersion":2,"position":[250,400],"parameters":{"mode":"runOnceForAllItems","jsCode":"const incoming = $input.first().json || {};\nconst headers = incoming.headers || {};\nconst body = incoming.body || {};\n\nfunction getHeader(name) {\n  const target = String(name).toLowerCase();\n  for (const [key, value] of Object.entries(headers)) {\n    if (String(key).toLowerCase() === target) {\n      return Array.isArray(value) ? value[0] : value;\n    }\n  }\n  return '';\n}\n\nconst authHeader = String(getHeader('authorization') || '');\nconst bearerToken = authHeader.replace(/^Bearer\\s+/i, '').trim();\nconst xAgentOSKey = String(getHeader('x-agentos-key') || '').trim();\n\nconst expectedKey = process.env.S_AGENTOS_OPERATOR_KEY || process.env.S_AGENTOS_API_TOKEN || '';\nconst providedToken = xAgentOSKey || bearerToken;\nconst isValid = Boolean(expectedKey && providedToken && providedToken === expectedKey);\n\nreturn [{\n  json: {\n    ...incoming,\n    body,\n    headers,\n    isValid,\n    auth_method: xAgentOSKey ? 'x-agentos-key' : (bearerToken ? 'bearer' : 'missing'),\n    token: providedToken ? '[REDACTED]' : 'missing'\n  }\n}];"}},
    {"id":"e6c477cb-26fd-4fae-94a3-0710cd8c3269","name":"IF — Auth Check","type":"n8n-nodes-base.if","typeVersion":2,"position":[250,600],"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"10a4c19c-e46f-4638-a7dd-3e0c36601672","leftValue":"={{ $json.isValid }}","rightValue":true,"operator":{"type":"boolean","operation":"equals","singleValue":true}}]},"combinator":"and"}},
    {"id":"b5c8f618-116d-4854-a7f2-c51a8ac9b977","name":"Code — Build Auth Error Response","type":"n8n-nodes-base.code","typeVersion":2,"position":[550,700],"parameters":{"mode":"runOnceForAllItems","jsCode":"return [{ json: { ok: false, error: 'Unauthorized', message: 'Invalid or missing Bearer token', code: 401 } }];"}},
    {"id":"8fdcd1bc-90df-415f-a0aa-4d819f88f317","name":"Respond to Webhook — Auth Error","type":"n8n-nodes-base.respondToWebhook","typeVersion":1.1,"position":[550,850],"parameters":{"options":{"responseCode":401},"respondWith":"json","responseBody":"={{ JSON.stringify($json) }}"}},
    {"id":"d1d7c1e1-f325-4505-b0eb-1ed5d87cb5f8","name":"Code — Extract & Validate Payload","type":"n8n-nodes-base.code","typeVersion":2,"position":[250,800],"parameters":{"mode":"runOnceForAllItems","jsCode":"const incoming = $input.first().json || {};\nconst body = incoming.body || {};\nconst errors = [];\n\nconst allowedPriorities = ['low', 'normal', 'medium', 'high', 'urgent', 'critical'];\nconst allowedRunModes = ['draft', 'dry_run', 'read_only', 'live'];\n\nif (!body.action || typeof body.action !== 'string') {\n  errors.push('Missing or invalid \"action\" field');\n}\n\nif (!body.objective || typeof body.objective !== 'string' || body.objective.trim() === '') {\n  errors.push('Missing or invalid \"objective\" field (required, non-empty string)');\n}\n\nif (body.priority && !allowedPriorities.includes(body.priority)) {\n  errors.push(`Invalid \"priority\" value. Allowed: ${allowedPriorities.join(', ')}`);\n}\n\nif (body.run_mode && !allowedRunModes.includes(body.run_mode)) {\n  errors.push(`Invalid \"run_mode\" value. Allowed: ${allowedRunModes.join(', ')}`);\n}\n\nconst isValid = errors.length === 0;\n\nreturn [{\n  json: {\n    ...incoming,\n    isValid,\n    errors,\n    body\n  }\n}];"}},
