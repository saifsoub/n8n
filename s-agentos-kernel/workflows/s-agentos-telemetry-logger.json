    "IF — event_type present?": {"main": [[{"node": "Supabase — Insert Telemetry", "type": "main", "index": 0}], [{"node": "Code — Validation Error", "type": "main", "index": 0}]]},
    "Code — Validation Error": {"main": [[{"node": "Respond to Webhook — Validation Error", "type": "main", "index": 0}]]},
    "Supabase — Insert Telemetry": {"main": [[{"node": "Code — Build Accepted Response", "type": "main", "index": 0}]]},
    "Code — Build Accepted Response": {"main": [[{"node": "Respond to Webhook — Accepted", "type": "main", "index": 0}]]}
  },
  "settings": {"executionOrder": "v1"},
