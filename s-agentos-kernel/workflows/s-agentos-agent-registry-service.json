    {
      "id": "42146bdf-5f16-497d-afc9-eff6625febfc",
      "name": "Code — Prepare Agent Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1280, -80],
      "parameters": {"jsCode": "const input = $input.first().json;\nconst agent_data = input.agent_data || {};\n\nconst hex = Math.random().toString(36).substring(2, 8).toUpperCase();\nconst agent_code = \"AGT-\" + hex;\n\nconst record = {\n  agent_code,\n  agent_name: agent_data.agent_name || \"Unnamed Agent\",\n  agent_type: agent_data.agent_type || \"general\",\n  purpose: agent_data.purpose || \"\",\n  responsibilities: agent_data.responsibilities || [],\n  inputs: agent_data.inputs || [],\n  outputs: agent_data.outputs || [],\n  tools_required: agent_data.tools_required || [],\n  memory_required: agent_data.memory_required || [],\n  evaluation_metrics: agent_data.evaluation_metrics || [],\n  capabilities: agent_data.capabilities || [],\n  deployment_status: \"draft\",\n  lifecycle_status: \"active\",\n  version: \"0.1\",\n  owner: agent_data.owner || \"operator\",\n  metadata: agent_data.metadata || {}\n};\n\nreturn [{ json: record }];"}
    },
